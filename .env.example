# Trino version to build/curl. Match a published GH release.
TRINO_VERSION=466

# Base image for the runtime build.
# Lab default: almalinux:9 (works offline once cached).
# On prem: your registry's UBI 9 mirror, e.g.
#   RUNTIME_BASE_IMAGE=registry.onprem.example.com/ubi9/ubi:latest
RUNTIME_BASE_IMAGE=almalinux:9

# Where Dockerfile.runtime curls the release tarball from. Override on prem
# if you mirror GH releases internally.
RELEASE_BASE_URL=https://github.com/kingfadzi/trino-el9/releases/download
